# =====================================================================
# AI Evaluation Platform - 生产环境变量配置示例
# 复制此文件为 .env.prod 并修改配置
# =====================================================================

# Docker 镜像配置
DOCKER_REGISTRY=ghcr.io/tstl198913
IMAGE_TAG=latest

# PostgreSQL 配置
POSTGRES_USER=eval
POSTGRES_PASSWORD=your_secure_password_here

# RabbitMQ 配置
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your_secure_password_here

# LLM API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 环境标识
ENV=production
