# =====================================================================
# AI Evaluation Platform - 环境变量配置
# 复制此文件为 .env 并填入实际值
# =====================================================================

# =====================================================================
# LLM API Keys (必需)
# =====================================================================
DEEPSEEK_API_KEY=sk-999e073bd5204fb6893fa3255f520fd6
OPENAI_API_KEY=your_openai_api_key_here

# =====================================================================
# 数据库配置 (PostgreSQL)
# =====================================================================
DATABASE_URL=postgresql://postgres:tiger13@localhost:5432/ai_eval_platform

# =====================================================================
# Redis 配置 (默认docker-compose中的值)
# =====================================================================
REDIS_URL=redis://localhost:6379

# =====================================================================
# RabbitMQ 配置 (默认docker-compose中的值)
# =====================================================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# =====================================================================
# Celery 配置
# =====================================================================
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =====================================================================
# API 配置
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# =====================================================================
# 认证配置
# =====================================================================
ADMIN_PASSWORD=admin123
USER_PASSWORD=user123
PASSWORD_SALT=fixed-salt-for-testing

# =====================================================================
# 日志配置
# =====================================================================
LOG_LEVEL=INFO
