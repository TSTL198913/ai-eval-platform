name: CI/CD Pipeline

on:
  push:
    branches: [main, master, develop]
    paths-ignore: ['README.md', 'docs/**', '*.md']
  pull_request:
    branches: [main, master]
    paths-ignore: ['README.md', 'docs/**', '*.md']

permissions:
  contents: read
  checks: write
  pull-requests: write

env:
  PYTHON_VERSION: '3.10'
  COVERAGE_THRESHOLD: '70'
  POSTGRES_TEST_PASSWORD: ${{ secrets.POSTGRES_TEST_PASSWORD || 'test123' }}

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint:
    name: Lint & Format
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
      - name: Install Ruff
        run: pip install ruff
      - name: Ruff Check (auto-fix)
        run: ruff check . --fix --cache-dir=.ruff_cache
      - name: Ruff Format
        run: ruff format . --cache-dir=.ruff_cache

  test-unit:
    name: Unit Tests
    runs-on: ubuntu-latest
    needs: lint
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
      - name: Install dependencies
        run: |
          pip install -r requirements.txt
          pip install pytest-cov pytest-xdist
      - name: Run unit tests
        run: |
          pytest tests/unit/ -n auto -v \
            --cov=src --cov-report=xml --cov-report=term-missing \
            --cov-fail-under=${{ env.COVERAGE_THRESHOLD }}

  integration-test:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 15
    needs: test-unit
    services:
      redis:
        image: redis:7-alpine
        ports: ['6379:6379']
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
      postgres:
        image: postgres:15-alpine
        env:
          POSTGRES_DB: ai_eval_test
          POSTGRES_USER: test
          POSTGRES_PASSWORD: ${{ env.POSTGRES_TEST_PASSWORD }}
        ports: ['5432:5432']
        options: >-
          --health-cmd "pg_isready -U test"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
      - name: Install dependencies
        run: pip install -r requirements.txt
      - name: Initialize database
        run: |
          python -c "from src.infra.db.session import init_tables; init_tables()"
        env:
          DATABASE_URL: postgresql://test:${{ env.POSTGRES_TEST_PASSWORD }}@localhost:5432/ai_eval_test
      - name: Run integration tests
        run: pytest tests/integration/ -v --tb=short
        env:
          DATABASE_URL: postgresql://test:${{ env.POSTGRES_TEST_PASSWORD }}@localhost:5432/ai_eval_test
          REDIS_URL: redis://localhost:6379

  docker-validate:
    name: Docker Build
    runs-on: ubuntu-latest
    needs: lint
    steps:
      - uses: actions/checkout@v4
      - uses: docker/setup-buildx-action@v3
      - name: Validate Dockerfile
        run: docker buildx build --pull --no-cache --output=type=docker,dest=/dev/null .

  security:
    name: Security Audit
    runs-on: ubuntu-latest
    needs: lint
    continue-on-error: true
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
      - name: Install security tools
        run: pip install pip-audit bandit
      - name: Run pip-audit
        run: |
          if [ -f requirements.txt ]; then
            pip-audit -r requirements.txt
          else
            echo "No requirements.txt found"
          fi
      - name: Run Bandit
        run: bandit -r src/ -f json -o bandit-report.json
      - name: Upload report
        uses: actions/upload-artifact@v4
        with:
          name: bandit-report
          path: bandit-report.json
          retention-days: 7

  risk-check:
    name: Risk Assessment
    runs-on: ubuntu-latest
    needs: test-unit
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
      - name: Install dependencies
        run: pip install -r requirements.txt
      - name: Run risk evaluation
        run: |
          python -m pytest tests/risk/ -v --tb=short

  summary:
    name: Workflow Summary
    runs-on: ubuntu-latest
    needs: [lint, test-unit, integration-test, docker-validate, security, risk-check]
    if: always()
    steps:
      - name: Build status table
        run: |
          echo "## CI/CD Pipeline Summary" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Job | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|-----|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| Lint | ${{ needs.lint.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Unit Tests | ${{ needs.test-unit.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Integration Tests | ${{ needs.integration-test.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Docker Build | ${{ needs.docker-validate.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Security Audit | ${{ needs.security.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Risk Assessment | ${{ needs.risk-check.result }} |" >> $GITHUB_STEP_SUMMARY
      - name: Fail on critical failures
        if: |
          needs.lint.result == 'failure' ||
          needs.test-unit.result == 'failure' ||
          needs.integration-test.result == 'failure' ||
          needs.docker-validate.result == 'failure'
        run: |
          echo "::error::Critical jobs failed"
          exit 1