# =====================================================================
# AI Evaluation Platform - 环境变量配置
# 复制此文件为 .env 并填入实际值
# =====================================================================

# =====================================================================
# LLM 模型配置 - 只需设置以下几项即可切换模型
# =====================================================================
# 选择模型提供者: deepseek, openai, anthropic, ollama, qwen, dashscope
LLM_PROVIDER=deepseek

# ---------------------------------------------------------------------
# DeepSeek 配置 (LLM_PROVIDER=deepseek)
# ---------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=  # 可选，自定义 API 地址

# ---------------------------------------------------------------------
# OpenAI 配置 (LLM_PROVIDER=openai)
# ---------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=  # 可选，自定义 API 地址（如本地代理）

# ---------------------------------------------------------------------
# Anthropic Claude 配置 (LLM_PROVIDER=anthropic)
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ---------------------------------------------------------------------
# Ollama 配置 (LLM_PROVIDER=ollama) - 本地部署模型
# ---------------------------------------------------------------------
OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434/api/chat  # 可选

# ---------------------------------------------------------------------
# 阿里云通义千问配置 (LLM_PROVIDER=qwen 或 dashscope)
# ---------------------------------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-max

# =====================================================================
# 数据库配置 (默认docker-compose中的值)
# =====================================================================
DATABASE_URL=postgresql://eval:eval123@localhost:5432/ai_eval

# =====================================================================
# Redis 配置 (默认docker-compose中的值)
# =====================================================================
REDIS_URL=redis://localhost:6379

# =====================================================================
# RabbitMQ 配置 (默认docker-compose中的值)
# =====================================================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# =====================================================================
# Celery 配置
# =====================================================================
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =====================================================================
# API 配置
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# =====================================================================
# 日志配置
# =====================================================================
LOG_LEVEL=INFO

# =====================================================================
# OpenTelemetry 配置 (可选)
# =====================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=