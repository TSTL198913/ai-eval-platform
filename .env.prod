# =====================================================================
# AI Evaluation Platform - ����������������
# =====================================================================

# Docker ��������
DOCKER_REGISTRY=ghcr.io/tstl198913
IMAGE_TAG=latest

# ������ʶ
ENV=production

# PostgreSQL 配置
POSTGRES_USER=eval
POSTGRES_PASSWORD=eval123
POSTGRES_DB=ai_eval
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://eval:eval123@postgres:5432/ai_eval
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# RabbitMQ 配置
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}

# Redis ����
REDIS_URL=redis://redis:6379/0

# Celery ����
CELERY_BROKER_URL=${RABBITMQ_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# LLM API Keys
DEEPSEEK_API_KEY=sk-5e5d625e3c7845959f8cc17c872a7169
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_LLM_PROVIDER=deepseek

# ��������
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_BURST=150

# �۶�������
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# ��������
EVALUATION_TIMEOUT=30
MAX_CONCURRENT_EVALUATIONS=10

# �������
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
