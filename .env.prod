# =====================================================================
# AI Evaluation Platform - 生产环境配置
# Docker Compose 环境使用服务名而非 localhost
# =====================================================================

# =====================================================================
# LLM 模型配置
# =====================================================================
LLM_PROVIDER=stub
# 生产环境请设置实际的 API Key
# DEEPSEEK_API_KEY=your_api_key
# OPENAI_API_KEY=your_api_key

# =====================================================================
# 数据库配置 - Docker 服务名
# =====================================================================
DATABASE_URL=postgresql://eval:eval123@postgres:5432/ai_eval

# =====================================================================
# Redis 配置 - Docker 服务名
# =====================================================================
REDIS_URL=redis://redis:6379/0

# =====================================================================
# RabbitMQ 配置 - Docker 服务名
# =====================================================================
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# =====================================================================
# Celery 配置 - Docker 服务名
# =====================================================================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =====================================================================
# API 配置
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# =====================================================================
# CORS 配置 - 生产环境
# =====================================================================
CORS_ORIGINS=http://localhost,http://localhost:80,http://ai-eval-frontend
