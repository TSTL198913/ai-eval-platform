# =====================================================================
# AI Evaluation Platform - 生产环境配置
# Docker Compose 环境使用服务名而非 localhost
# =====================================================================

# =====================================================================
# 数据库配置 - Docker 服务名
# =====================================================================
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DATABASE_URL=postgresql://eval:eval123@postgres:5432/ai_eval

# =====================================================================
# RabbitMQ 配置 - Docker 服务名
# =====================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
# 展开变量（.env 不支持 ${VAR} 语法）
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# =====================================================================
# Redis 配置 - Docker 服务名
# =====================================================================
REDIS_URL=redis://redis:6379/0

# =====================================================================
# Celery 配置 - Docker 服务名
# =====================================================================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =====================================================================
# LLM 配置
# =====================================================================
LLM_PROVIDER=deepseek
# 生产环境请设置实际的 API Key
DEEPSEEK_API_KEY=sk-999e073bd5204fb6893fa3255f520fd6

# =====================================================================
# API 配置
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# =====================================================================
# 限流配置
# =====================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_BURST=150

# =====================================================================
# 熔断器配置
# =====================================================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# =====================================================================
# 评测配置
# =====================================================================
EVALUATION_TIMEOUT=30
MAX_CONCURRENT_EVALUATIONS=10

# =====================================================================
# 监控配置
# =====================================================================
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false

# =====================================================================
# CORS 配置 - 生产环境
# =====================================================================
CORS_ORIGINS=http://localhost,http://localhost:80,http://ai-eval-frontend
